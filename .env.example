# ── Kafka ──────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_HIGH=sec_events_high
KAFKA_TOPIC_MEDIUM=sec_events_medium
KAFKA_TOPIC_LOW=sec_events_low

# ── Blockchain ─────────────────────────────────────
BLOCKCHAIN_MOCK=true
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_CHANNEL=security-channel
FABRIC_CHAINCODE=seclogger

# ── Priority Engine ────────────────────────────────
W_CONFIDENCE=0.35
W_SEVERITY=0.35
W_ASSET_VALUE=0.20
W_RECENCY=0.10
THRESHOLD_HIGH=0.75
THRESHOLD_MEDIUM=0.45

# ── Merkle Batcher ─────────────────────────────────
BATCH_WINDOW_MS=300
BATCH_MAX_SIZE=100

# ── Load Generator ─────────────────────────────────
LOAD_INSTANCES_START=100
LOAD_INSTANCES_END=10000
LOAD_EVENTS_PER_SEC=1000
ANOMALY_RATIO=0.05

# ── Prometheus ─────────────────────────────────────
PROMETHEUS_PORT=8000

# ── General ────────────────────────────────────────
LOG_LEVEL=INFO
RESULTS_DIR=results
